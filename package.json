{
  "name": "ikkfms-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "NODE_ENV=development electron .",
    "dev:electron": "concurrently \"next dev\" \"sleep 3 && NODE_ENV=development electron .\"",
    "seed": "node scripts/seed.mjs",
    "predist": "npm rebuild better-sqlite3",
    "predist:win": "npm rebuild better-sqlite3",
    "predist:mac": "npm rebuild better-sqlite3",
    "dist": "npm run build && node scripts/prepare-standalone.js && electron-builder",
    "dist:win": "npm run build && node scripts/prepare-standalone.js --target=win32 && electron-builder --win",
    "dist:mac": "npm run build && node scripts/prepare-standalone.js --target=darwin && electron-builder --mac",
    "dist:all": "node -e \"console.error('Use platform-specific CI jobs: run dist:mac on macOS and dist:win on Windows.'); process.exit(1)\""
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.1.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.ikkfms.app",
    "productName": "IKKFMS",
    "electronDist": "node_modules/electron/dist",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-standalone/",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data/",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "assets/icons/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns"
    }
  }
}
